  "List Warp with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-warps port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :gpu_accelerator.Warp/id))
         rows (apply-filters rows (:filter opts) [:gpu_accelerator.Warp/smId :gpu_accelerator.Warp/threads :gpu_accelerator.Warp/scheduler :gpu_accelerator.Warp/occupancy])]
     (paginate rows opts))))

(defn get-warp
  "Retrieve a Warp by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-warp port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-warp
  "Update a Warp; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :smId) (conj [:db/add id :gpu_accelerator.Warp/smId (get data :smId)]))
                   (cond-> (contains? data :threads) (conj [:db/add id :gpu_accelerator.Warp/threads (as-long (get data :threads))]))
                   (cond-> (contains? data :scheduler) (conj [:db/add id :gpu_accelerator.Warp/scheduler (get data :scheduler)]))
                   (cond-> (contains? data :occupancy) (conj [:db/add id :gpu_accelerator.Warp/occupancy (as-double (get data :occupancy))]))
                   (conj [:db/add id :gpu_accelerator.Warp/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-warp
  "Delete a Warp."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

