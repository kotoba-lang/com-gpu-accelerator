;; collection → CRUD fns, keyed by the /v1/<collection> path segment
(def ^:private handlers
  {"gpus" {:create create-gpu :list list-gpus :get get-gpu :update update-gpu :delete delete-gpu}
   "streamingmultiprocessors" {:create create-streaming-multiprocessor :list list-streaming-multiprocessors :get get-streaming-multiprocessor :update update-streaming-multiprocessor :delete delete-streaming-multiprocessor}
   "tensorcores" {:create create-tensor-core :list list-tensor-cores :get get-tensor-core :update update-tensor-core :delete delete-tensor-core}
   "memoryhierarchies" {:create create-memory-hierarchy :list list-memory-hierarchies :get get-memory-hierarchy :update update-memory-hierarchy :delete delete-memory-hierarchy}
   "warps" {:create create-warp :list list-warps :get get-warp :update update-warp :delete delete-warp}
   "kernellaunches" {:create create-kernel-launch :list list-kernel-launches :get get-kernel-launch :update update-kernel-launch :delete delete-kernel-launch}})

(defn- expand-opts [params]
  (when-let [x (:expand params)]
    {:expand (set (map keyword (str/split (str x) #",")))}))

(defn dispatch
  "Route an HTTP-ish request through `routes` to the CRUD fns.
   req: {:method (:get/:post/:patch/:delete) :path /v1/<coll>[/<id>] :params {} :body {}}.
   Returns {:status int :body any} — the runnable L4 service surface."
  [port {:keys [method path params body]}]
  (let [segs (->> (str/split (or path "") #"/") (remove str/blank?) vec)
        coll (get segs 1)
        id   (get segs 2)
        h    (get handlers coll)
        params (or params {})]
    (cond
      (nil? h) {:status 404 :body {:error "unknown collection"}}
      (and (= method :post) (nil? id)) {:status 201 :body ((:create h) port (or body params))}
      (and (= method :get) (nil? id)) {:status 200 :body ((:list h) port params)}
      (and (= method :get) id) (if-let [r ((:get h) port id (expand-opts params))]
                                 {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (#{:patch :put} method) id) (if-let [r ((:update h) port id (or body params))]
                                         {:status 200 :body r} {:status 404 :body {:error "not found"}})
      (and (= method :delete) id) {:status 200 :body ((:delete h) port id)}
      :else {:status 405 :body {:error "method not allowed"}})))

