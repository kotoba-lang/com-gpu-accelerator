;; ── DatomPort — the DI seam to the kotoba Datom log ───────────────────────
(defprotocol DatomPort
  (-transact [this tx-data]
    "Append Datomic-shaped tx-data: entity maps {:db/id … attr v}, [:db/add e a v],
     [:db/retract e a v], [:db/retractEntity e].")
  (-pull [this eid]
    "Return the entity map for eid (incl. :db/id), or nil.")
  (-find-by-attr [this attr]
    "AEVT scan: the eids of every entity carrying attr."))

;; loud-failing default — a forgotten injection must never silently no-op
(defn unwired-datom []
  (reify DatomPort
    (-transact [_ _] (throw (ex-info "gpu_accelerator: DatomPort not wired — inject kotoba-kqe or in-memory-datom" {:unwired true})))
    (-pull [_ _] (throw (ex-info "gpu_accelerator: DatomPort not wired" {:unwired true})))
    (-find-by-attr [_ _] (throw (ex-info "gpu_accelerator: DatomPort not wired" {:unwired true})))))

;; in-memory fake — interprets the Datomic tx-data subset over {eid {attr v}}
(defn in-memory-datom []
  (let [store (atom {})]
    (reify DatomPort
      (-transact [_ tx-data]
        (doseq [op tx-data]
          (cond
            (map? op) (swap! store update (:db/id op) merge (dissoc op :db/id))
            (and (vector? op) (= :db/add (first op)))
            (let [[_ e a v] op] (swap! store assoc-in [e a] v))
            (and (vector? op) (= :db/retract (first op)))
            (let [[_ e a] op] (swap! store update e dissoc a))
            (and (vector? op) (= :db/retractEntity (first op)))
            (let [[_ e] op] (swap! store dissoc e))))
        {:db-after @store})
      (-pull [_ eid] (when-let [m (get @store eid)] (assoc m :db/id eid)))
      (-find-by-attr [_ attr] (vec (for [[eid m] @store :when (contains? m attr)] eid))))))

;; ── coercion (portable) ───────────────────────────────────────────────────
(defn- as-long [v]
  (cond (number? v) #?(:clj (long v) :cljs v)
        (string? v) (try #?(:clj (Long/parseLong (str/trim v))
                            :cljs (let [n (js/parseInt v 10)] (if (js/isNaN n) 0 n)))
                         (catch #?(:clj Exception :cljs :default) _ 0))
        :else 0))

(defn- as-double [v]
  (cond (number? v) #?(:clj (double v) :cljs v)
        (string? v) (try #?(:clj (Double/parseDouble (str/trim v))
                            :cljs (let [n (js/parseFloat v)] (if (js/isNaN n) 0.0 n)))
                         (catch #?(:clj Exception :cljs :default) _ 0.0))
        :else 0.0))

(defn- as-bool [v]
  (boolean (#{"1" "true" "yes" "on" true} (if (string? v) (str/lower-case v) v))))

(defn- now []
  #?(:clj (str (java.time.Instant/now)) :cljs (.toISOString (js/Date.))))

(defn- new-id [prefix]
  (str prefix "_" (subs (str/replace (str (random-uuid)) "-" "") 0 16)))

(defn- require-fields [data fields]
  (let [missing (remove (fn [k] (some? (get data (keyword k)))) fields)]
    (when (seq missing)
      (throw (ex-info (str "Missing required fields: " (str/join ", " missing))
                      {:type :invalid-request :missing (vec missing)})))))

;; ── list surface: filtering + cursor pagination (L4 parity) ───────────────
(def ^:const default-limit 20)
(def ^:const max-limit 100)

(defn- index-of [v x]
  (loop [i 0] (cond (>= i (count v)) -1 (= (nth v i) x) i :else (recur (inc i)))))

(defn- apply-filters
  "Keep rows matching every {attr v} in flt (string-compared), attr restricted to allowed."
  [rows flt allowed]
  (let [allowed (set allowed)]
    (reduce (fn [rs [a v]]
              (if (and (contains? allowed a) (some? v))
                (filterv (fn [r] (= (str (get r a)) (str v))) rs)
                rs))
            (vec rows) (or flt {}))))

(defn- paginate
  "Cursor pagination over rows → {:object :data :has-more :count :total}.
   opts {:limit N :starting-after <db/id>}."
  [rows opts]
  (let [limit (min (max (or (:limit opts) default-limit) 1) max-limit)
        start (:starting-after opts)
        rows  (vec rows)
        rows  (if start
                (let [idx (index-of (mapv :db/id rows) start)]
                  (if (neg? idx) rows (subvec rows (inc idx))))
                rows)
        page  (vec (take limit rows))]
    {:object "list" :data page :has-more (> (count rows) limit)
     :count (count page) :total (count rows)}))

;; ── Gpu ────────────────────────────────────────────────────────────────
(defn create-gpu
  "Create a Gpu."
  [port data]
  (require-fields data ["name" "architecture"])
  (let [id (new-id "gpu_gpu")
        e {:db/id id
           :gpu_accelerator.Gpu/id id
           :gpu_accelerator.Gpu/name (get data :name)
           :gpu_accelerator.Gpu/architecture (get data :architecture)
           :gpu_accelerator.Gpu/smCount (as-long (get data :smCount))
           :gpu_accelerator.Gpu/vramGb (as-long (get data :vramGb))
           :gpu_accelerator.Gpu/tflops (as-double (get data :tflops))
           :gpu_accelerator.Gpu/createdAt (now)
           :gpu_accelerator.Gpu/updatedAt (now)}]
    (-transact port [e])
    e))

(defn list-gpus
  "List Gpu with optional filtering + cursor pagination → L4 list map.
   opts: {:filter {<attr-kw> v} :limit N :starting-after <db/id>}."
  ([port] (list-gpus port {}))
  ([port opts]
   (let [rows (mapv (fn [e] (-pull port e)) (-find-by-attr port :gpu_accelerator.Gpu/id))
         rows (apply-filters rows (:filter opts) [:gpu_accelerator.Gpu/name :gpu_accelerator.Gpu/architecture :gpu_accelerator.Gpu/smCount :gpu_accelerator.Gpu/vramGb :gpu_accelerator.Gpu/tflops])]
     (paginate rows opts))))

(defn get-gpu
  "Retrieve a Gpu by id; opts {:expand #{:field}} inlines referenced entities. nil if absent."
  ([port id] (get-gpu port id nil))
  ([port id opts]
   (when-let [rec (-pull port id)]
     (let [want (:expand opts)]
       (cond-> rec)))))

(defn update-gpu
  "Update a Gpu; returns the new entity map, or nil if absent."
  [port id data]
  (when (-pull port id)
    (let [sets (-> []
                   (cond-> (contains? data :name) (conj [:db/add id :gpu_accelerator.Gpu/name (get data :name)]))
                   (cond-> (contains? data :architecture) (conj [:db/add id :gpu_accelerator.Gpu/architecture (get data :architecture)]))
                   (cond-> (contains? data :smCount) (conj [:db/add id :gpu_accelerator.Gpu/smCount (as-long (get data :smCount))]))
                   (cond-> (contains? data :vramGb) (conj [:db/add id :gpu_accelerator.Gpu/vramGb (as-long (get data :vramGb))]))
                   (cond-> (contains? data :tflops) (conj [:db/add id :gpu_accelerator.Gpu/tflops (as-double (get data :tflops))]))
                   (conj [:db/add id :gpu_accelerator.Gpu/updatedAt (now)]))]
      (-transact port sets)
      (-pull port id))))

(defn delete-gpu
  "Delete a Gpu."
  [port id]
  (-transact port [[:db/retractEntity id]])
  {:id id :deleted true})

