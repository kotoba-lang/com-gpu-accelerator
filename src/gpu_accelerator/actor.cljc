  (let [id (new-id "gpu_ker")
        e {:db/id id
           :gpu_accelerator.KernelLaunch/id id
           :gpu_accelerator.KernelLaunch/gpuId (get data :gpuId)
           :gpu_accelerator.KernelLaunch/name (get data :name)
           :gpu_accelerator.KernelLaunch/gridDim (as-long (get data :gridDim))
           :gpu_accelerator.KernelLaunch/blockDim (as-long (get data :blockDim))
           :gpu_accelerator.KernelLaunch/status (get data :status)
           :gpu_accelerator.KernelLaunch/createdAt (now)
           :gpu_accelerator.KernelLaunch/updatedAt (now)}]
